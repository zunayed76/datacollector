use App\Models\User;
use App\Models\Submission;
use App\Models\Address;
use App\Models\Education;
use App\Models\Language;
use App\Models\Division;
use App\Models\District;
use App\Models\Thana;
use Illuminate\Support\Facades\Hash;

public function run(): void
{
    // 1. Create Divisions, Districts, and Thanas (Your existing code)
    $divisionsData = [
        'Dhaka' => ['Dhaka', 'Gazipur', 'Narayanganj'],
        'Chattogram' => ['Chattogram', 'Cox\'s Bazar', 'Cumilla'],
        'Rajshahi' => ['Rajshahi', 'Bogra', 'Pabna'],
        'Khulna' => ['Khulna', 'Jashore', 'Satkhira'],
        'Barishal' => ['Barishal', 'Bhola', 'Patuakhali'],
        'Sylhet' => ['Sylhet', 'Moulvibazar', 'Habiganj'],
    ];

    foreach ($divisionsData as $divName => $districts) {
        $division = Division::factory()->create(['name' => $divName]);
        foreach ($districts as $distName) {
            $district = District::factory()->create([
                'division_id' => $division->id,
                'name' => $distName
            ]);
            Thana::factory()->count(3)->create([
                'district_id' => $district->id
            ]);
        }
    }

    // 2. Create 20 Users
    $users = User::factory()->count(20)->create([
        'role' => 'user',
        'password' => Hash::make('password'),
    ]);

    // Get all geography IDs for random assignment
    $allThanas = Thana::with('district.division')->get();

    // 3. Create 300 Submissions (15 per user on average)
    for ($i = 0; $i < 300; $i++) {
        $user = $users->random();
        
        $submission = Submission::factory()->create([
            'user_id' => $user->id,
            'name' => fake()->name(),
            'nid_number' => fake()->numerify('##########'),
            'date_of_birth' => fake()->date(),
        ]);

        // 4. Create Addresses for each submission
        foreach (['present', 'permanent'] as $type) {
            $location = $allThanas->random();
            Address::create([
                'submission_id' => $submission->id,
                'type' => $type,
                'division_id' => $location->district->division_id,
                'district_id' => $location->district_id,
                'thana_id' => $location->id,
                'location_details' => fake()->address(),
            ]);
        }

        // 5. Create 1-3 Education records per submission
        Education::factory()->count(rand(1, 3))->create([
            'submission_id' => $submission->id,
        ]);

        // 6. Create 1-2 Language records per submission
        Language::create([
            'submission_id' => $submission->id,
            'language_name' => 'English',
            'proficiency_level' => fake()->randomElement(['Beginner', 'Intermediate', 'Fluent', 'Native']),
        ]);
        
        if(rand(0, 1)) {
            Language::create([
                'submission_id' => $submission->id,
                'language_name' => 'Bengali',
                'proficiency_level' => 'Native',
            ]);
        }
    }
}
